# Copy the variable names below into Railway -> Service -> Variables.
# Do NOT commit real secrets to GitHub.

# ---- Core app URLs ----
APP_BASE_URL=https://your-backend.up.railway.app
FRONTEND_URL=https://your-frontend-domain.com
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000,http://localhost:5500

# ---- Database (map from Railway MySQL service or your external MySQL) ----
SPRING_DATASOURCE_URL=jdbc:mysql://<MYSQL_HOST>:<MYSQL_PORT>/<MYSQL_DATABASE>?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=<MYSQL_USER>
SPRING_DATASOURCE_PASSWORD=<MYSQL_PASSWORD>

# ---- JWT ----
JWT_SECRET=<BASE64_SECRET_AT_LEAST_32_BYTES>
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ---- Optional admin basic auth ----
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=<CHANGE_ME>
SPRING_SECURITY_LOG_LEVEL=INFO

# ---- VNPay ----
VNPAY_TMN_CODE=<YOUR_VNPAY_TMN_CODE>
VNPAY_HASH_SECRET=<YOUR_VNPAY_HASH_SECRET>
VNPAY_API_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-frontend-domain.com/payment-result
VNPAY_NOTIFY_URL=https://your-backend.up.railway.app/api/payments/vnpay/ipn

# ---- Email ----
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=<YOUR_EMAIL>
SPRING_MAIL_PASSWORD=<YOUR_APP_PASSWORD>
APP_MAIL_FROM=noreply@fashionable-shop.com

# ---- Google OAuth2 ----
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
